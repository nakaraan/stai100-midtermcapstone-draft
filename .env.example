# Copy this file to .env and fill in real values. Never commit the real .env.

# --- NREL / NSRDB API --- sign up for a free key at https://developer.nlr.gov/signup/
NREL_API_KEY=your-nrel-api-key
NREL_API_EMAIL=you@example.com
# NREL_NSRDB_BASE_URL=https://developer.nlr.gov/api/nsrdb/v2/solar/himawari-download.json
# NREL_REQUEST_TIMEOUT_SECONDS=60

# --- LLM (any OpenAI-compatible endpoint) --- defaults target a local Ollama server
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2:3b

# --- MLflow --- point this at a tracking server you run separately (see README)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=agent-p-solar-analytics
# MLFLOW_REGISTRY_URI=

# --- Used only by app/ui.py to reach the FastAPI backend ---
AGENT_P_API_URL=http://localhost:8000
