{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "agent-api",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "agent-ui",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "streamlit", "run", "app/ui.py", "--server.port", "8501", "--server.headless", "true"],
      "port": 8501
    }
  ]
}
